{
  "mcpServers": {
    "alpaca": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "ALPACA_API_KEY",
        "-e", "ALPACA_SECRET_KEY",
        "-e", "ALPACA_PAPER_TRADE=true",
        "mcp/alpaca:latest", "alpaca-mcp-server", "--transport", "stdio"
      ]
    },
    "alpaca-p1": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "ALPACA_API_KEY=${ALPACA_API_KEY_P1}",
        "-e", "ALPACA_SECRET_KEY=${ALPACA_SECRET_KEY_P1}",
        "-e", "ALPACA_PAPER_TRADE=true",
        "mcp/alpaca:latest", "alpaca-mcp-server", "--transport", "stdio"
      ]
    },
    "binance": {
      "command": "C:\\Users\\GAR\\.jdks\\openjdk-25\\bin\\java.exe",
      "args": [
        "-jar",
        "C:\\Users\\GAR\\Documents\\POC\\BinanceMCP\\BinanceMCP\\target\\binance-mcp-server-0.1.0.jar"
      ],
      "env": {
        "BINANCE_TRADING_ENABLED": "false"
      }
    }
  }
}
